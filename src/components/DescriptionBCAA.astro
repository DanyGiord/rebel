---
import { TriangleAlert } from 'lucide-astro';
---

<section class="desc-section">
  <div class="desc-inner">

    <div class="desc-left">
      <div class="desc-tag">
        <span class="tag-line"></span>Food Supplement
      </div>
      <h2 class="desc-title">REBEL<br/><span>BCAA</span></h2>
      <p class="desc-subtitle">With sweeteners</p>

      <div class="desc-meta">
        <div class="meta-item">
          <span class="meta-num">380<small>g</small></span>
          <span class="meta-lbl">Net quantity</span>
        </div>
        <div class="meta-div"></div>
        <div class="meta-item">
          <span class="meta-num">27</span>
          <span class="meta-lbl">Servings</span>
        </div>
        <div class="meta-div"></div>
        <div class="meta-item">
          <span class="meta-num">2:1:1</span>
          <span class="meta-lbl">BCAA ratio</span>
        </div>
      </div>
    </div>

    <div class="desc-right">
      <div class="body-text">
        <p class="lead">
          A complex of high-quality branched-chain amino acids (BCAA), enriched with
          L-glutamine, taurine and citrulline malate. Designed specifically for athletes
          and physically active people.
        </p>

        <p>
          BCAAs are essential amino acids leucine, isoleucine and valine, popular in the
          sports world because they are supposed to reduce muscle soreness and exercise
          fatigue, shorten recovery time, prevent muscle breakdown, and increase muscle growth.
        </p>

        <p>
          BCAAs also act as a source of energy for muscles during workouts and are therefore
          a perfect all-round food supplement. If your fitness goals are to build muscle and
          improve performance, then this product is a must-have in your essential training kit.
        </p>

        <p>
          REBEL BCAA combines the proven ratio (2:1:1) of branched-chain amino acids with
          additional key performance ingredients such as L-glutamine, L-taurine and citrulline malate.
        </p>

        <div class="serving-breakdown">
          <div class="sb-header">
            <span class="tag-line"></span>Each serving contains
          </div>
          <div class="sb-rows">
            <div class="sb-row">
              <span class="sb-val">5 <small>g</small></span>
              <span class="sb-name">BCAA</span>
              <span class="sb-detail">L-leucine, L-isoleucine & L-valine in 2:1:1 ratio</span>
            </div>
            <div class="sb-row">
              <span class="sb-val">3 <small>g</small></span>
              <span class="sb-name">L-Glutamine</span>
              <span class="sb-detail"></span>
            </div>
            <div class="sb-row">
              <span class="sb-val">2 <small>g</small></span>
              <span class="sb-name">L-Taurine</span>
              <span class="sb-detail"></span>
            </div>
            <div class="sb-row">
              <span class="sb-val">500 <small>mg</small></span>
              <span class="sb-name">Citrulline Malate</span>
              <span class="sb-detail"></span>
            </div>
          </div>
        </div>

        <p class="timing-note">
          Enjoy before, during or after physical exercise to support your muscles and performance.
        </p>

        <!-- Recommended Use -->
        <div class="usage-block">
          <div class="usage-header">
            <span class="tag-line"></span>Recommended Use
          </div>
          <div class="usage-steps">
            <div class="usage-step">
              <span class="step-num">01</span>
              <div class="step-body">
                <span class="step-title">Serving size</span>
                <span class="step-text">2 scoops (14 g)</span>
              </div>
            </div>
            <div class="usage-step">
              <span class="step-num">02</span>
              <div class="step-body">
                <span class="step-title">Mix with</span>
                <span class="step-text">400–500 ml water</span>
              </div>
            </div>
            <div class="usage-step">
              <span class="step-num">03</span>
              <div class="step-body">
                <span class="step-title">When to take</span>
                <span class="step-text">Before and during exercise, or between meals.</span>
              </div>
            </div>
          </div>
          <div class="usage-warning">
            <TriangleAlert size={14} />
            <p>Do not exceed the recommended daily dose. Do not use as a substitute for a balanced diet. Keep out of reach of children.</p>
          </div>
        </div>

        <!-- Nutrition -->
        <div class="nutrition-block">
          <div class="nutr-header">
            <span class="nutr-label">Nutrition Information</span>
            <span class="nutr-sub">BATTERY REBEL BCAA — RASPBERRY SPLASH</span>
          </div>
          <table class="nutr-table">
            <thead>
              <tr>
                <th></th>
                <th>Per serving (14 g)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>L-Leucine</td>
                <td>2 500 mg</td>
              </tr>
              <tr>
                <td>L-Valine</td>
                <td>1 250 mg</td>
              </tr>
              <tr>
                <td>L-Isoleucine</td>
                <td>1 250 mg</td>
              </tr>
              <tr>
                <td>L-Glutamine</td>
                <td>3 000 mg</td>
              </tr>
              <tr>
                <td>L-Taurine</td>
                <td>2 000 mg</td>
              </tr>
              <tr>
                <td>Citrulline Malate</td>
                <td>500 mg</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Ingredients -->
        <div class="ingredients-block">
          <div class="ing-header">
            <span class="ing-tag">RASPBERRY SPLASH</span>
            <span class="ing-label">Ingredients</span>
          </div>
          <p class="ing-main">BCAA blend (L-leucine, L-isoleucine, L-valine), L-glutamine, L-taurine, inulin, acidity regulator (citric acid), flavouring (raspberry), L-citrulline malate 1:1, colour (beetroot red), sweeteners (acesulfame K, sucralose).</p>
          <p class="ing-allergen">
            May contain traces of
            <strong>egg</strong>, <strong>gluten</strong>, <strong>soy</strong>,
            <strong>peanuts</strong>, <strong>nuts</strong>, <strong>fish</strong>,
            <strong>crustacean</strong> and <strong>sulphur dioxide</strong>.
          </p>
        </div>

      </div>
    </div>

  </div>

  <div class="desc-divider"></div>
</section>

<style>
  .desc-section {
    position: relative;
    background: #070707;
    color: #ffffff;
    font-family: 'Rajdhani', sans-serif;
    padding: 100px 0 80px;
  }

  .desc-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 64px;
    display: grid;
    grid-template-columns: 38% 62%;
    gap: 80px;
    align-items: start;
  }

  /* LEFT */
  .desc-left {
    position: sticky;
    top: 40px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .desc-tag {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.28em;
    color: #e8003d;
    text-transform: uppercase;
  }

  .tag-line {
    display: block;
    width: 28px;
    height: 1px;
    background: #e8003d;
    flex-shrink: 0;
  }

  .desc-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 5vw, 76px);
    line-height: 0.88;
    margin: 0;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.9);
  }

  .desc-title span {
    background: linear-gradient(120deg, #e8003d, #ff6b6b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .desc-subtitle {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin: 0;
  }

  .desc-meta {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid rgba(255,255,255,0.07);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .meta-item { display: flex; flex-direction: column; gap: 4px; }

  .meta-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 38px;
    line-height: 1;
    color: #ffffff;
  }

  .meta-num small { font-size: 0.55em; color: #e8003d; }

  .meta-lbl {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.32);
  }

  .meta-div { width: 1px; height: 40px; background: rgba(255,255,255,0.08); flex-shrink: 0; }

  /* RIGHT */
  .body-text {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .body-text p {
    margin: 0;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.75;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.01em;
  }

  .body-text .lead {
    font-size: 18px;
    font-weight: 500;
    color: rgba(255,255,255,0.78);
    line-height: 1.65;
    padding-left: 20px;
    border-left: 2px solid #e8003d;
  }

  /* Serving breakdown */
  .serving-breakdown {
    border: 1px solid rgba(255,255,255,0.08);
    overflow: hidden;
  }

  .sb-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #e8003d;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.02);
  }

  .sb-rows { display: flex; flex-direction: column; }

  .sb-row {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    transition: background 0.15s;
  }

  .sb-row:last-child { border-bottom: none; }
  .sb-row:hover { background: rgba(232,0,61,0.04); }

  .sb-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    line-height: 1;
    color: #e8003d;
  }

  .sb-val small {
    font-size: 0.5em;
    color: rgba(232,0,61,0.65);
  }

  .sb-name {
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.85);
    text-transform: uppercase;
  }

  .sb-detail {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.28);
    text-align: right;
  }

  .timing-note {
    font-family: 'IBM Plex Mono', monospace !important;
    font-size: 12px !important;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.38) !important;
    line-height: 1.7 !important;
    padding: 16px 20px;
    border: 1px solid rgba(232,0,61,0.12);
    background: rgba(232,0,61,0.03);
  }

  /* Recommended Use */
  .usage-block { display: flex; flex-direction: column; gap: 24px; }

  .usage-header {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #e8003d;
  }

  .usage-steps {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .usage-step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    background: #070707;
  }

  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    line-height: 1;
    color: rgba(255,255,255,0.1);
    flex-shrink: 0;
    min-width: 28px;
  }

  .step-body { display: flex; flex-direction: column; gap: 4px; }

  .step-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .step-text {
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.78);
    line-height: 1.4;
  }

  .usage-warning {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 20px;
    border: 1px solid rgba(255,200,0,0.12);
    background: rgba(255,200,0,0.03);
  }

  .usage-warning svg { color: rgba(255,200,0,0.6); flex-shrink: 0; margin-top: 2px; }

  .usage-warning p {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(255,200,0,0.5);
    line-height: 1.7;
    margin: 0;
  }

  /* Nutrition */
  .nutrition-block { border: 1px solid rgba(255,255,255,0.08); overflow: hidden; }

  .nutr-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 18px 24px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.02);
  }

  .nutr-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .nutr-sub {
    font-family: 'Rajdhani', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
  }

  .nutr-table { width: 100%; border-collapse: collapse; }

  .nutr-table thead th {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    padding: 12px 24px;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .nutr-table thead th:last-child { text-align: right; color: #e8003d; }

  .nutr-table tbody td {
    padding: 14px 24px;
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: rgba(255,255,255,0.75);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }

  .nutr-table tbody td:last-child {
    text-align: right;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    color: #ffffff;
  }

  .nutr-table tbody tr:last-child td { border-bottom: none; }

  /* Ingredients */
  .ingredients-block {
    padding: 28px;
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: rgba(255,255,255,0.02);
  }

  .ing-header { display: flex; align-items: center; gap: 14px; }

  .ing-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #070707;
    background: #e8003d;
    padding: 4px 10px;
    font-weight: 700;
  }

  .ing-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .ing-main {
    font-family: 'Rajdhani', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    margin: 0;
    letter-spacing: 0.02em;
    line-height: 1.55;
  }

  .ing-allergen {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.32);
    line-height: 1.7;
    margin: 0;
  }

  .ing-allergen strong { color: rgba(255,255,255,0.6); font-weight: 500; }

  /* Divider */
  .desc-divider {
    max-width: 1440px;
    margin: 80px auto 0;
    padding: 0 64px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08) 30%, rgba(255,255,255,0.08) 70%, transparent);
  }

  @media (max-width: 1200px) {
    .desc-inner { padding: 0 40px; }
  }

  @media (max-width: 1024px) {
    .usage-steps { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 900px) {
    .desc-inner { grid-template-columns: 1fr; padding: 0 32px; gap: 40px; }
    .desc-left { position: static; }
    .sb-row { grid-template-columns: 70px 1fr; }
    .sb-detail { display: none; }
    .desc-divider { padding: 0 32px; margin-top: 48px; }
    .usage-steps { grid-template-columns: 1fr; }
  }

  @media (max-width: 680px) {
    .usage-steps { grid-template-columns: 1fr; }
    .nutr-table { font-size: 13px; }
    .nutr-table th, .nutr-table td { padding: 10px 14px; }
  }

  @media (max-width: 480px) {
    .desc-section { padding: 56px 0 60px; }
    .desc-inner { padding: 0 20px; }
    .desc-divider { padding: 0 20px; }
    .desc-title { font-size: 52px; }
    .nutr-table { font-size: 12px; }
    .nutr-table th, .nutr-table td { padding: 8px 10px; }
  }

  @media (max-width: 380px) {
    .desc-inner { padding: 0 16px; }
    .sb-row { grid-template-columns: 60px 1fr; }
  }
</style>
