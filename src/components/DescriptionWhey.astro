---
import { TriangleAlert } from 'lucide-astro';
---

<section class="desc-section">
  <div class="desc-inner">

    <div class="desc-left">
      <div class="desc-tag">
        <span class="tag-line"></span>Food Supplement
      </div>
      <h2 class="desc-title">REBEL<br/><span>WHEY</span></h2>
      <p class="desc-subtitle">Whey Concentrate &amp; Isolate Blend</p>

      <div class="desc-meta">
        <div class="meta-item">
          <span class="meta-num">700<small>g</small></span>
          <span class="meta-lbl">Net quantity</span>
        </div>
        <div class="meta-div"></div>
        <div class="meta-item">
          <span class="meta-num">21</span>
          <span class="meta-lbl">Servings</span>
        </div>
        <div class="meta-div"></div>
        <div class="meta-item">
          <span class="meta-num">25<small>g</small></span>
          <span class="meta-lbl">Protein / serving</span>
        </div>
      </div>
    </div>

    <div class="desc-right">
      <div class="body-text">
        <p class="lead">
          Food supplement with sweeteners. A mixture for preparation of a high protein drink.
        </p>

        <p>
          Building muscle requires good nutrition. Using supplements can help you meet your
          nutrition needs and support your fitness goals. When trying to gain muscle, protein
          powders are by far the most convenient and easy way to increase your daily protein intake.
        </p>

        <p>
          Proteins are responsible for muscle growth and recovery in athletes and other active
          population. Protein intake is especially vital to increase and maintain lean body mass.
          In order to grow muscles, you need to maintain a positive protein balance. Protein
          requirements can vary significantly, ranging from 1,2 g to 3,1 g per kilogram of body
          weight per day.
        </p>

        <p>
          REBEL WHEY PROTEIN powdered drink is a convenient, tasty, and affordable way to get
          the protein you need. With just one serving you will increase your protein intake for
          25 g protein, derived from whey protein concentrate and whey protein isolate. Whey
          protein is one of the best dietary sources of high-quality protein. It is highly
          digestible and absorbed quickly compared to other proteins. It is considered a complete
          protein that provides all three branched chain amino acids (BCAAs) and delivers all
          nine essential amino acids.
        </p>

        <p>
          REBEL WHEY PROTEIN is available in 3 popular user-tested and approved flavours:
          vanilla, strawberry, and chocolate-hazelnut.
        </p>

        <p class="footnote">
          * A balanced and varied diet and a healthy lifestyle are important.<br/>
          Net quantity: 700 g / 1800 g
        </p>
      </div>
    </div>
  </div>

  <!-- Serving breakdown -->
  <div class="nutrition-block">
    <div class="nb-header">
      <span class="tag-line"></span>
      <span class="nb-label">Per 33g serving</span>
    </div>
    <div class="sb-grid">
      <div class="sb-row">
        <span class="sb-name">Whey Protein Concentrate</span>
        <span class="sb-val">25 g</span>
      </div>
      <div class="sb-row">
        <span class="sb-name">of which BCAA</span>
        <span class="sb-val">5.5 g</span>
      </div>
      <div class="sb-row">
        <span class="sb-name">Carbohydrates</span>
        <span class="sb-val">2.1 g</span>
      </div>
      <div class="sb-row">
        <span class="sb-name">Fat</span>
        <span class="sb-val">1.8 g</span>
      </div>
      <div class="sb-row">
        <span class="sb-name">Energy</span>
        <span class="sb-val">126 kcal</span>
      </div>
    </div>
  </div>

  <!-- Recommended Use -->
  <div class="usage-block">
    <div class="section-header">
      <span class="tag-line"></span>
      <span class="section-label">Recommended Use</span>
    </div>

    <div class="usage-steps">
      <div class="usage-step">
        <span class="step-num">01</span>
        <div class="step-body">
          <strong>Serving size</strong>
          <p>1 scoop (32 g) mixed with 250 ml water or milk.</p>
        </div>
      </div>
      <div class="usage-step">
        <span class="step-num">02</span>
        <div class="step-body">
          <strong>Timing</strong>
          <p>Consume 1–2 servings a day: upon awakening, between meals, after training or before sleep.</p>
        </div>
      </div>
      <div class="usage-step">
        <span class="step-num">03</span>
        <div class="step-body">
          <strong>Mix</strong>
          <p>Mix 1 serving with 250 ml water or milk and shake well.</p>
        </div>
      </div>
    </div>

    <div class="usage-warning">
      <TriangleAlert size={16} />
      <p>Keep out of reach of children! Don't exceed the recommended daily dosage! This product should not be used as a substitute for a varied and balanced diet. A varied and balanced diet and a healthy lifestyle are recommended.</p>
    </div>

    <p class="timing-note">Store in a dry place, away from heat and direct sunlight.</p>
  </div>

  <!-- Nutrition table -->
  <div class="nutrition-block">
    <div class="section-header">
      <span class="tag-line"></span>
      <span class="section-label">Nutrition Information</span>
    </div>

    <!-- Chocolate Hazelnut -->
    <div class="nutr-flavour-block">
      <span class="flavour-tag chocolate">CHOCOLATE HAZELNUT</span>
      <table class="nutr-table">
        <thead>
          <tr>
            <th>Nutrient</th>
            <th>Per 100g</th>
            <th>Per serving (32g)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Energy</td><td>1568 kJ / 371 kcal</td><td>502 kJ / 119 kcal (6%)*</td></tr>
          <tr><td>Fat</td><td>0,6 g</td><td>0,2 g (&lt;1%)*</td></tr>
          <tr><td>— of which saturates</td><td>0,2 g</td><td>0,1 g (&lt;1%)*</td></tr>
          <tr><td>Carbohydrate</td><td>12 g</td><td>3,9 g (2%)*</td></tr>
          <tr><td>— of which sugars</td><td>6,6 g</td><td>2,1 g (2%)*</td></tr>
          <tr><td>Protein</td><td>77 g</td><td>25 g (49%)*</td></tr>
          <tr><td>Salt</td><td>0,89 g</td><td>0,28 g (5%)*</td></tr>
          <tr><td>Digestive enzymes</td><td>100 mg</td><td>32 mg</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Strawberry -->
    <div class="nutr-flavour-block">
      <span class="flavour-tag strawberry">STRAWBERRY</span>
      <table class="nutr-table">
        <thead>
          <tr>
            <th>Nutrient</th>
            <th>Per 100g</th>
            <th>Per serving (32g)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Energy</td><td>1577 kJ / 373 kcal</td><td>504 kJ / 119 kcal (6%)*</td></tr>
          <tr><td>Fat</td><td>0,3 g</td><td>0,1 g (&lt;1%)*</td></tr>
          <tr><td>— of which saturates</td><td>0 g</td><td>0 g (0%)*</td></tr>
          <tr><td>Carbohydrate</td><td>12 g</td><td>3,8 g (2%)*</td></tr>
          <tr><td>— of which sugars</td><td>5,9 g</td><td>1,9 g (2%)*</td></tr>
          <tr><td>Protein</td><td>79 g</td><td>25 g (51%)*</td></tr>
          <tr><td>Salt</td><td>0,90 g</td><td>0,29 g (5%)*</td></tr>
          <tr><td>Digestive enzymes</td><td>100 mg</td><td>32 mg</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Vanilla -->
    <div class="nutr-flavour-block">
      <span class="flavour-tag vanilla">VANILLA</span>
      <table class="nutr-table">
        <thead>
          <tr>
            <th>Nutrient</th>
            <th>Per 100g</th>
            <th>Per serving (32g)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Energy</td><td>1574 kJ / 373 kcal</td><td>504 kJ / 119 kcal (6%)*</td></tr>
          <tr><td>Fat</td><td>0,3 g</td><td>0,1 g (&lt;1%)*</td></tr>
          <tr><td>— of which saturates</td><td>0 g</td><td>0 g (0%)*</td></tr>
          <tr><td>Carbohydrate</td><td>12 g</td><td>3,8 g (2%)*</td></tr>
          <tr><td>— of which sugars</td><td>5,9 g</td><td>1,9 g (2%)*</td></tr>
          <tr><td>Protein</td><td>79 g</td><td>25 g (51%)*</td></tr>
          <tr><td>Salt</td><td>0,89 g</td><td>0,28 g (5%)*</td></tr>
          <tr><td>Digestive enzymes</td><td>100 mg</td><td>32 mg</td></tr>
        </tbody>
      </table>
    </div>

    <p class="nutr-ref">*Reference intake of an average adult (8400 kJ / 2000 kcal).</p>
  </div>

  <!-- Ingredients -->
  <div class="ingredients-block">
    <div class="section-header">
      <span class="tag-line"></span>
      <span class="section-label">Ingredients</span>
    </div>

    <div class="ingr-block">
      <span class="flavour-tag chocolate">CHOCOLATE HAZELNUT</span>
      <p class="ingredients-text">
        Whey protein blend (whey protein concentrate from <strong>MILK</strong> &#123;instantized with sunflower lecithin&#125;, whey protein isolate from <strong>MILK</strong> &#123;instantized with sunflower lecithin&#125;), l-glycine, skimmed <strong>MILK</strong> powder, maltodextrine, fat reduced cocoa powder (10–12%), flavourings, sodium chloride, thickener (xanthan), sweeteners (acesulfame K, sucralose), digezyme® enzyme complex (alpha-amylase, neutral protease, cellulase, lactase, lipase).
      </p>
    </div>

    <div class="ingr-block">
      <span class="flavour-tag strawberry">STRAWBERRY</span>
      <p class="ingredients-text">
        Whey protein blend (whey protein concentrate from <strong>MILK</strong> &#123;instantized with sunflower lecithin&#125;, whey protein isolate from <strong>MILK</strong> &#123;instantized with sunflower lecithin&#125;), l-glycine, skimmed <strong>MILK</strong> powder, maltodextrine, flavouring, sodium chloride, colour (beetroot red), sweeteners (acesulfame K, sucralose), thickener (xanthan), digezyme® enzyme complex (alpha-amylase, neutral protease, cellulase, lactase, lipase).
      </p>
    </div>

    <div class="ingr-block">
      <span class="flavour-tag vanilla">VANILLA</span>
      <p class="ingredients-text">
        Whey protein blend (whey protein concentrate from <strong>MILK</strong> &#123;instantized with sunflower lecithin&#125;, whey protein isolate from <strong>MILK</strong> &#123;instantized with sunflower lecithin&#125;), l-glycine, skimmed <strong>MILK</strong> powder, maltodextrine, flavourings, sodium chloride, thickener (xanthan), sweeteners (acesulfame K, sucralose), digezyme® enzyme complex (alpha-amylase, neutral protease, cellulase, lactase, lipase).
      </p>
    </div>

    <p class="allergen-note">
      May contain traces of egg, gluten, soy, peanuts, nuts, fish, crustaceans and sulphur dioxide.
    </p>
  </div>
</section>

<style>
  :root {
    --c: #9d4edd;
    --m: #ffd60a;
  }

  .desc-section {
    background: #070707;
    color: #fff;
    font-family: 'Rajdhani', sans-serif;
    padding: 100px 0 120px;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  /* ── Top two-col ── */
  .desc-inner {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 64px;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 48px;
    align-items: start;
  }

  .desc-left {
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky;
    top: 40px;
  }

  .desc-tag {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c);
  }

  .tag-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--c);
    flex-shrink: 0;
  }

  .desc-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 5vw, 80px);
    line-height: 0.88;
    margin: 0;
    color: rgba(255,255,255,0.9);
  }

  .desc-title span {
    background: linear-gradient(125deg, var(--c) 0%, var(--m) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .desc-subtitle {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin: 0;
  }

  .desc-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    line-height: 1;
    color: #fff;
  }

  .meta-num small {
    font-size: 0.5em;
    color: var(--m);
  }

  .meta-lbl {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  .meta-div {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,0.1);
  }

  /* ── Body text ── */
  .body-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .body-text p {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    margin: 0;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .body-text .lead {
    font-size: 18px;
    color: rgba(255,255,255,0.75);
    font-weight: 500;
    line-height: 1.6;
  }

  .body-text .footnote {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.28);
    padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  /* ── Shared block styles ── */
  .nutrition-block,
  .usage-block,
  .ingredients-block {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 48px;
  }

  .section-header,
  .nb-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 32px;
  }

  .section-label,
  .nb-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  /* ── Serving breakdown ── */
  .sb-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .sb-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .sb-name {
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.65);
  }

  .sb-val {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: var(--c);
    letter-spacing: 0.1em;
  }

  /* ── Usage steps ── */
  .usage-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 32px;
  }

  .usage-step {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(157,78,221,0.03);
  }

  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 40px;
    line-height: 1;
    color: rgba(157,78,221,0.3);
  }

  .step-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .step-body strong {
    font-family: 'Rajdhani', sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
  }

  .step-body p {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255,255,255,0.48);
    margin: 0;
  }

  /* ── Warning ── */
  .usage-warning {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px 24px;
    border: 1px solid rgba(255,214,10,0.18);
    background: rgba(255,214,10,0.04);
    margin-bottom: 16px;
    color: rgba(255,214,10,0.8);
  }

  .usage-warning p {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    line-height: 1.6;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.45);
    margin: 0;
  }

  .timing-note {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.28);
    margin: 0;
  }

  /* ── Nutrition table ── */
  .nutr-flavour-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 32px;
  }

  .nutr-flavour-block:last-of-type {
    border-bottom: none;
    margin-bottom: 0;
  }

  .nutr-ref {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.25);
    margin: 0;
    padding-top: 16px;
  }

  .nutr-table {
    width: 100%;
    border-collapse: collapse;
  }

  .nutr-table th {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    text-align: left;
    padding: 0 0 16px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .nutr-table td {
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    letter-spacing: 0.03em;
  }

  .nutr-table td:last-child {
    color: var(--c);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
  }

  /* ── Ingredients ── */
  .flavour-tags {
    display: flex;
    gap: 10px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .flavour-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 6px 14px;
    border: 1px solid;
  }

  .flavour-tag.chocolate {
    color: #cd7c3a;
    border-color: rgba(205,124,58,0.35);
    background: rgba(205,124,58,0.06);
  }

  .flavour-tag.vanilla {
    color: #ffd60a;
    border-color: rgba(255,214,10,0.35);
    background: rgba(255,214,10,0.06);
  }

  .flavour-tag.strawberry {
    color: #ff6b9d;
    border-color: rgba(255,107,157,0.35);
    background: rgba(255,107,157,0.06);
  }

  .ingr-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 24px;
  }

  .ingr-block:last-of-type {
    border-bottom: none;
    margin-bottom: 0;
  }

  .ingredients-text {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    margin: 0 0 16px;
    letter-spacing: 0.02em;
  }

  .allergen-note {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.35);
    margin: 0;
    line-height: 1.6;
  }

  .allergen-note strong {
    color: rgba(255,214,10,0.7);
  }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .desc-inner, .nutrition-block, .usage-block, .ingredients-block { padding: 0 40px; }
  }

  @media (max-width: 1024px) {
    .usage-steps { grid-template-columns: 1fr; }
  }

  @media (max-width: 900px) {
    .desc-inner { grid-template-columns: 1fr; padding: 0 32px; gap: 40px; }
    .desc-left { position: static; }
    .nutrition-block, .usage-block, .ingredients-block { padding: 0 32px; }
  }

  @media (max-width: 680px) {
    .nutr-table { font-size: 13px; }
    .nutr-table th, .nutr-table td { padding: 10px 12px; }
    .nutr-flavour-block { overflow-x: auto; }
    .sb-grid { font-size: 14px; }
    .sb-row { padding: 12px 0; }
  }

  @media (max-width: 600px) {
    .desc-section { padding: 56px 0 72px; gap: 52px; }
    .desc-inner, .nutrition-block, .usage-block, .ingredients-block { padding: 0 20px; }
    .flavour-tags { gap: 8px; }
    .ingr-block { padding-bottom: 20px; margin-bottom: 20px; }
  }

  @media (max-width: 420px) {
    .desc-inner, .nutrition-block, .usage-block, .ingredients-block { padding: 0 16px; }
    .desc-title { font-size: 52px; }
    .nutr-table { font-size: 11px; }
    .nutr-table th, .nutr-table td { padding: 8px 8px; }
    .nutr-flavour-block { padding-bottom: 16px; margin-bottom: 16px; }
    .sb-row { flex-direction: column; gap: 4px; align-items: flex-start; }
    .sb-val { font-size: 12px; }
  }
</style>
